      "id": "rule-getuser-suspended",
      "name": "GetUser — Suspended Account",
      "enabled": true,
      "endpoint": "/graphql",
      "operationName": "GetUser",
      "operationMatchType": "exact",
      "queryRegex": "",
      "variableConditions": [
        { "field": "userId", "operator": "equals", "value": "suspended-user" }
      ],
      "response": {
        "data": {
          "user": {
            "id": "suspended-user",
            "name": "Suspended User",
            "email": "suspended@example.com",
            "status": "SUSPENDED",
            "suspendedAt": "2024-01-15T00:00:00Z",
            "suspendReason": "Terms of Service violation"
          }
        }
      },
      "statusCode": 200,
      "priority": 10,
      "groupId": "group-edge-cases",
      "delay": 0,
      "createdAt": 1708300000000,
      "updatedAt": 1708300000000
    },
